{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "types": ["node"],
    "maxNodeModuleJsDepth": 2
  },
  "typeAcquisition": {
    "enable": true
  },
  "include": ["**/*.js"],
  "exclude": ["node_modules", "dist"]
}
